# Vercel → Elastic otel-demo | project: metrics-compare
# Import in Vercel: Settings → Environment Variables (or push-vercel-elastic-env.sh)

# Vercel environment variables → Elastic otel-demo (a5630c)
# Copy these into each Vercel project: Settings → Environment Variables
# Or run: ES_API_KEY=... ./scripts/push-vercel-elastic-env.sh
#
# Apply to: Production, Preview, and Development (or Production + Preview only).
#
# OTLP ingest (traces, metrics, logs) — NOT the Kibana URL.

# ── Required ────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://a5630c65c43f4f299288c392af0c2f45.ingest.us-east-1.aws.elastic.cloud:443
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Per-project — change for each Vercel deployment (e.g. telco-agent, snortai)
OTEL_SERVICE_NAME=metrics-compare

# Used by some apps (e.g. metrics-compare) alongside OTEL_EXPORTER_OTLP_HEADERS
OTEL_API_KEY=ZjBTVDlwNEJQeDFEeVdQeXdXSnA6MmlUNzNlZFB0eU5EeHNUcTk1VnpjQQ

# Server-side only — EDOT Browser OTLP proxy (same key; never expose to browser)
ELASTIC_OTLP_API_KEY=ZjBTVDlwNEJQeDFEeVdQeXdXSnA6MmlUNzNlZFB0eU5EeHNUcTk1VnpjQQ

# ── Resource attributes ─────────────────────────────────────────────────────
# Vercel sets VERCEL_ENV (production | preview | development) automatically.
OTEL_RESOURCE_ATTRIBUTES=elastic.cloud.deployment=otel-demo-a5630c
OTEL_DEPLOYMENT_ENVIRONMENT=production

# ── Elasticsearch (server-side queries from Vercel functions, optional) ───
ELASTICSEARCH_URL=https://otel-demo-a5630c.es.us-east-1.aws.elastic.cloud
ELASTICSEARCH_API_KEY=ZjBTVDlwNEJQeDFEeVdQeXdXSnA6MmlUNzNlZFB0eU5EeHNUcTk1VnpjQQ
ELASTIC_CLOUD_KIBANA=https://otel-demo-a5630c.kb.us-east-1.aws.elastic.cloud

# ── Next.js / Vercel OTEL tuning ────────────────────────────────────────────
# Set to 1 for extra Next.js spans (noisy in production)
NEXT_OTEL_VERBOSE=0
# Disable if using custom fetch instrumentation
# NEXT_OTEL_FETCH_DISABLED=0

# ── Disable telemetry locally (optional) ────────────────────────────────────
# OTEL_SDK_DISABLED=true
